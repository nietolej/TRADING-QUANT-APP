# Entorno de base de datos
DB_URL=sqlite:///data/trading_quant.db

# Binance API (solo lectura / testnet para Fase 1-2)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=True

# Datos On-Chain
COINGECKO_API_KEY=your_coingecko_free_api_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key_here
# DefiLlama y Blockchain.com no requieren key para uso básico

# Telegram Bot (Fase 2-3)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Configuraciones Globales
LOG_LEVEL=INFO
